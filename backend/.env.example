# ─────────────────────────────────────────────────────────────────────────────
# AdhesiveFlow ERP – Backend Environment Variables
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="InstaBiz Industrial ERP"
APP_VERSION="2.0.0"
DEBUG=false

# ── Database (PostgreSQL 15+) ─────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://erp_user:CHANGE_ME@localhost:5432/adhesive_erp

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: comma-separated list of allowed origins
# Development: * (open)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/erp_uploads
MAX_UPLOAD_SIZE=10485760   # 10 MB

# ── AI / LLM Integration ──────────────────────────────────────────────────────
# Anthropic Claude (primary LLM for AI agents)
ANTHROPIC_API_KEY=

# Google Generative AI (fallback / Document IO OCR)
GOOGLE_AI_API_KEY=

# OpenAI (optional fallback via LiteLLM)
OPENAI_API_KEY=

# Emergent LLM gateway (used by routes/ai_bi.py, buying_dna.py, etc.)
EMERGENT_LLM_KEY=

# ── AWS S3 (optional – for file storage in production) ────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_S3_BUCKET=

# ── GST / E-Invoice APIs ──────────────────────────────────────────────────────
# NIC / IRP sandbox URL for e-invoice generation
EINVOICE_API_URL=https://einv-apisandbox.nic.in
EINVOICE_API_USER=
EINVOICE_API_PASS=

# ── WhatsApp Notifications ────────────────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ── Stripe (optional – for SaaS billing) ─────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
